# 🐄 DAIRY MANAGEMENT SYSTEM - FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# Vite automatically loads .env (no need to source it)

# ========== API BASE URL ==========
# Backend API URL
# Local development: http://localhost:5000/api
# Production: https://your-backend.onrender.com/api (or your backend hosting)
VITE_API_URL=http://localhost:5000/api

# ========== APPLICATION SETTINGS ==========
# App name (optional)
VITE_APP_NAME=Dairy Management System

# ========== DEVELOPMENT ==========
# Set to true for development logging
VITE_DEBUG=false
