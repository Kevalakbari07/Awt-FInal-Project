# 🐄 DAIRY MANAGEMENT SYSTEM - BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (add to .gitignore)

# ========== SERVER ==========
# Port for Express server (default: 5000)
PORT=5000

# ========== DATABASE ==========
# MongoDB connection string
# Local development: mongodb://127.0.0.1:27017/dairyDB
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dairyDB?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/dairyDB

# ========== JWT & SECURITY ==========
# Secret key for JWT token generation (use a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# ========== DEPLOYMENT ==========
# Frontend URL for CORS (add your production frontend URL here)
# Examples:
# - http://localhost:5173 (local development)
# - https://your-frontend.vercel.app (production)
FRONTEND_URL=http://localhost:5173

# ========== ADMIN ACCOUNT ==========
# Default admin credentials (auto-created on startup)
# Username must be lowercase for signup
ADMIN_USERNAME=astro@133790
ADMIN_PASSWORD=Rachit@672

# ========== OPTIONAL: NODE ENVIRONMENT ==========
# Set to "production" for production deployment
NODE_ENV=development
